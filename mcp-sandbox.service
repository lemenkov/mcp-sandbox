[Unit]
Description=MCP Scientific Sandbox Server
After=network.target

[Service]
Type=simple
User=sandbox
EnvironmentFile=/etc/sysconfig/mcp-sandbox
WorkingDirectory=/opt/mcp-servers/mcp-sandbox
ExecStart=/opt/mcp-servers/mcp-sandbox/venv/bin/mcp-sandbox
Restart=on-failure
RestartSec=5s
StandardOutput=journal
StandardError=journal
SyslogIdentifier=mcp-sandbox
CPUQuota=150%
KillMode=control-group

[Install]
WantedBy=multi-user.target
